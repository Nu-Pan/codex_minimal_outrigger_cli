#!/bin/sh

set -eu

cmoc_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
venv_python="$cmoc_root/.venv/bin/python"
# User-facing path reports follow {{work-root}}/oracle/src/oracle/other/path_model.py.
display_script_path="{{cmoc-root}}/bin/cmoc"

# interpreter が通常の実行可能ファイルでない場合も wrapper のエラー報告へ送る。
# {{work-root}}/oracle/doc/dev_rule/development_environment.md
is_usable_venv_python() {
    [ -f "$venv_python" ] && [ -x "$venv_python" ]
}

line_number_of() {
    pattern=$1
    awk -v pattern="$pattern" '$0 ~ pattern { print NR; exit }' "$0"
}

print_missing_venv_error() {
    {
        printf '%s\n' "# ERROR"
        printf '%s\n' "## Summary"
        printf '%s\n' "cmoc の仮想環境 Python が見つからないか、実行できません。"
        printf '%s\n' "## Next actions"
        printf '%s\n' "- 初回セットアップの場合は、仮想環境を作成して cmoc をインストールしてください。"
        printf '%s\n' "- 既にセットアップ済みの場合は、.venv の削除や権限変更が起きていないか確認してください。"
        printf '%s\n' "## Detail"
        printf '%s\n' "必要な実行ファイル: $venv_python"
        printf '%s\n' "セットアップ手順:"
        printf '%s\n' "  cd \"$cmoc_root\""
        printf '%s\n' "  /usr/bin/python3 -m venv .venv"
        printf '%s\n' "  ./.venv/bin/python -m pip install -e ."
        printf '%s\n' "## Call stack"
        printf '%s\n' "  at print_missing_venv_error ($display_script_path:$(line_number_of "^print_missing_venv_error[(][)] [{]$"))"
        printf '%s\n' "  at require_venv_python ($display_script_path:$(line_number_of "^    print_missing_venv_error$"))"
        printf '%s\n' "  at main ($display_script_path:$(line_number_of "^require_venv_python$"))"
    }
}

require_venv_python() {
    if is_usable_venv_python; then
        return 0
    fi
    print_missing_venv_error
    exit 1
}

is_completion_probe() {
    [ "${_CMOC_COMPLETE+x}" = x ]
}

if is_completion_probe; then
    if is_usable_venv_python; then
        exec "$venv_python" "$cmoc_root/src/main.py" "$@"
    fi
    exit 1
fi

require_venv_python

exec "$venv_python" "$cmoc_root/src/main.py" "$@"

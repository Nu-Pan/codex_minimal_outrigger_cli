{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operations"
  ],
  "properties": {
    "operations": {
      "type": "array",
      "description": "入力された所見リストの重複や矛盾を解消するための編集操作リスト。十分コンパクトで整合的な場合は空配列を返す。",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "target_ids",
              "finding"
            ],
            "properties": {
              "kind": {
                "const": "delete",
                "description": "所見を削除する編集操作。"
              },
              "target_ids": {
                "type": "array",
                "description": "削除対象となる入力所見の finding_id のリスト。",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "finding": {
                "type": "null",
                "description": "delete では編集後の所見内容を持たない。"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "target_ids",
              "finding"
            ],
            "properties": {
              "kind": {
                "const": "replace",
                "description": "単一所見を置き換える編集操作。"
              },
              "target_ids": {
                "type": "array",
                "description": "置換対象となる入力所見の finding_id のリスト。",
                "minItems": 1,
                "maxItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "finding": {
                "$ref": "#/$defs/finding",
                "description": "置換後の新しい所見内容。"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "target_ids",
              "finding"
            ],
            "properties": {
              "kind": {
                "const": "merge",
                "description": "複数所見を統合する編集操作。"
              },
              "target_ids": {
                "type": "array",
                "description": "統合元となる入力所見の finding_id のリスト。",
                "minItems": 2,
                "items": {
                  "type": "string"
                }
              },
              "finding": {
                "$ref": "#/$defs/finding",
                "description": "統合後の新しい所見内容。"
              }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "title",
        "oracle_path",
        "reason"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "description": "所見の重大度。仕様断片同士の明確な矛盾、または仕様に従う実装時に実装者裁量では解消不能な問題は fatal。日本語的な誤り、誤字・脱字・助詞抜け、用語不統一・表記揺れ・typo など表記上の単純な問題は minor。",
          "enum": [
            "fatal",
            "minor"
          ]
        },
        "title": {
          "type": "string",
          "description": "所見の短い見出し。問題の要点が分かるように簡潔に書く。"
        },
        "oracle_path": {
          "type": "string",
          "description": "所見の主な根拠となる oracle file のパス。対象所見群の根拠として最も適切な oracle file を指す。"
        },
        "reason": {
          "type": "string",
          "description": "編集後の所見として扱うべき理由。重複や矛盾をどう整理したかも分かるように書く。"
        }
      }
    }
  }
}

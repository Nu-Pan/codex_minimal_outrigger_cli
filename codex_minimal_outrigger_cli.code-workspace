{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"files.exclude": {
			"**/__pycache__": true,
			"**/*.egg-info": true
		},
		"[python]": {
			"editor.defaultFormatter": "ms-python.black-formatter",
			"editor.formatOnSave": true
		},
		"[markdown]": {
			"editor.insertSpaces": true,
			"editor.tabSize": 4,
			"editor.detectIndentation": false
		}
	}
}

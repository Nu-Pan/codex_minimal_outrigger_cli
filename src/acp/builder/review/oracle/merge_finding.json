{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operations"
  ],
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "title",
        "oracle_path",
        "reason"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "description": "所見の重大度。仕様断片として致命的な矛盾・欠落は fatal、軽微な曖昧さ・改善余地は minor。",
          "enum": [
            "fatal",
            "minor"
          ]
        },
        "title": {
          "type": "string",
          "description": "所見の短い見出し。問題の要点が分かるように簡潔に書く。"
        },
        "oracle_path": {
          "type": "string",
          "description": "所見の主な根拠となる oracle file のパス。対象所見または対象所見群の根拠として最も適切な oracle file を指す。"
        },
        "reason": {
          "type": "string",
          "description": "編集後の所見として扱うべき理由。置換・統合で何をどう整理したかも分かるように書く。"
        }
      }
    }
  },
  "properties": {
    "operations": {
      "type": "array",
      "description": "入力された所見リストの重複や矛盾を解消するための編集操作リスト。十分コンパクトで整合的な場合は空配列を返す。",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "target_ids",
              "finding"
            ],
            "properties": {
              "kind": {
                "const": "delete",
                "description": "所見を削除する編集操作。"
              },
              "target_ids": {
                "type": "array",
                "description": "削除対象となる入力所見の finding_id のリスト。",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "finding": {
                "type": "null",
                "description": "delete では新しい所見を作らないため null。"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "target_ids",
              "finding"
            ],
            "properties": {
              "kind": {
                "const": "replace",
                "description": "単一所見を編集後の新しい所見へ置き換える編集操作。"
              },
              "target_ids": {
                "type": "array",
                "description": "置き換え対象となる入力所見の finding_id。replace では必ず 1 件だけ指定する。",
                "minItems": 1,
                "maxItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "finding": {
                "$ref": "#/$defs/finding"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "target_ids",
              "finding"
            ],
            "properties": {
              "kind": {
                "const": "merge",
                "description": "複数所見を編集後の新しい所見へ統合する編集操作。"
              },
              "target_ids": {
                "type": "array",
                "description": "統合元となる入力所見の finding_id のリスト。merge では必ず 2 件以上指定する。",
                "minItems": 2,
                "items": {
                  "type": "string"
                }
              },
              "finding": {
                "$ref": "#/$defs/finding"
              }
            }
          }
        ]
      }
    }
  }
}
